<Project>
  <!--
    Copy this file to "Directory.Build.props" next to SynergyHighlight.sln and set paths for your machine.
    Directory.Build.props is gitignored so your layout stays local only.
  -->
  <PropertyGroup>
    <GameDir>C:\Path\To\Your\HollywoodAnimal\game</GameDir>
    <BepInExDir>C:\Path\To\Your\BepInEx</BepInExDir>
  </PropertyGroup>
</Project>
